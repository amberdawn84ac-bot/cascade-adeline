# ============================================================
# Dear Adeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Only OPENAI_API_KEY is strictly required to get started.
# ============================================================

# --- REQUIRED ---

# OpenAI (default LLM + embeddings + vision + moderation)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Supabase PostgreSQL (database)
# Get yours at: https://supabase.com → New Project → Settings → Database
#
# ⚠️ CRITICAL: You need TWO database URLs:
#
# 1. DATABASE_URL (Transaction Pooler - port 6543):
#    - Used for app runtime queries (API routes, serverless functions)
#    - Prevents connection exhaustion in serverless environments
#    - MUST include "pgbouncer=true" parameter
#
# 2. DIRECT_DATABASE_URL (Direct Connection - port 5432):
#    - Used ONLY for database migrations and schema changes
#    - Required for `prisma db push`, `prisma migrate`, and DDL operations
#    - Transaction poolers REJECT schema changes, so this must be direct
#
# If you only set DATABASE_URL, migrations will fail with cryptic errors.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Supabase Auth
# Get yours at: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Upstash Redis (caching + rate limiting)
# Get yours at: https://upstash.com → Create Database
UPSTASH_REDIS_REST_URL="https://YOUR_DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AcivAA..."

# --- OPTIONAL (enhance specific features) ---

# Anthropic (used for INVESTIGATE intent — Claude 3 Sonnet)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Google Gemini (alternative LLM provider)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# Tavily (web search for DiscernmentEngine investigations)
# Get yours at: https://tavily.com
TAVILY_API_KEY=""

# --- APP SECRETS ---

# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Run this command 4 times to generate unique secrets for each variable below
APP_ENCRYPTION_KEY="replace-with-48-char-hex-secret"
SESSION_SECRET="replace-with-48-char-hex-secret"
CRON_SECRET="replace-with-48-char-hex-secret"

# Secret used to authenticate the /api/users POST webhook (called by Supabase on new user signup)
USER_PROVISION_SECRET="replace-with-48-char-hex-secret"

# --- EMAIL (Resend) ---

# Get yours at: https://resend.com → API Keys
RESEND_API_KEY="re_..."
EMAIL_FROM="Adeline <hello@dear-adeline.com>"

# --- STRIPE (subscriptions + payments) ---

# Get yours at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Webhook Secret (from Stripe Dashboard → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create products in Stripe Dashboard → copy price IDs)
STRIPE_PRICE_STUDENT_MONTHLY=""
STRIPE_PRICE_STUDENT_YEARLY=""
STRIPE_PRICE_PARENT_MONTHLY=""
STRIPE_PRICE_PARENT_YEARLY=""
STRIPE_PRICE_FAMILY_MONTHLY=""
STRIPE_PRICE_FAMILY_YEARLY=""

# --- ANALYTICS (PostHog) ---

# Get yours at: https://posthog.com → Project → Settings
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- PRISMA (optional — Prisma Accelerate for edge caching) ---

# Get yours at: https://www.prisma.io/data-platform/accelerate
PRISMA_ACCELERATE_URL=""

# Direct DB URL for migrations (bypasses connection pooler)
DIRECT_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# --- DEPLOYMENT ---

# Local: http://localhost:3000  |  Production: https://dearadeline.co
NEXT_PUBLIC_APP_URL="http://localhost:3000"
