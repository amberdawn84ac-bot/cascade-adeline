model CachedLesson {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  creditId    String   @map("credit_id")
  gradeLevel  String   @default("") @map("grade_level")
  subject     String
  title       String
  lessonData  Json     @map("lesson_data")
  generatedAt DateTime @default(now()) @map("generated_at")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation("CachedLessons", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, creditId, gradeLevel])
  @@index([userId])
  @@index([expiresAt])
  @@map("cached_lessons")
}

model DailyReflection {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  date      DateTime
  prompt    String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  student   User     @relation("StudentReflections", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([studentId])
  @@index([date])
  @@map("daily_reflections")
}

model BookClub {
  id        String           @id @default(uuid()) @db.Uuid
  name      String
  bookId    String           @map("book_id")
  bookTitle String           @map("book_title")
  active    Boolean          @default(true)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  members   BookClubMember[]
  posts     BookClubPost[]

  @@index([active])
  @@map("book_clubs")
}

model BookClubMember {
  id       String   @id @default(uuid()) @db.Uuid
  clubId   String   @map("club_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")
  club     BookClub @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
  @@index([clubId])
  @@map("book_club_members")
}

model BookClubPost {
  id        String   @id @default(uuid()) @db.Uuid
  clubId    String   @map("club_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  content   String   @db.Text
  isAdeline Boolean  @default(false) @map("is_adeline")
  chapter   String?  @map("chapter")
  createdAt DateTime @default(now()) @map("created_at")
  club      BookClub @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clubId])
  @@index([createdAt])
  @@map("book_club_posts")
}
