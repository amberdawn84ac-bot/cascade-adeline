generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserMFACredential {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  secret      String
  backupCodes Json     @map("backup_codes")
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([enabled])
}

model UserActivity {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  activityType String   @map("activity_type")
  duration     Int      @default(30)
  metadata     Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation("UserActivities", fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([activityType])
}

model CollaborativeSession {
  id             String        @id @default(uuid()) @db.Uuid
  hostUserId     String        @map("host_user_id") @db.Uuid
  participantIds Json          @map("participant_ids")
  topic          String
  status         SessionStatus @default(ACTIVE)
  startTime      DateTime      @default(now()) @map("start_time")
  endTime        DateTime?     @map("end_time")
  sharedInsights Json?         @map("shared_insights")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  host           User          @relation("HostedSessions", fields: [hostUserId], references: [id])

  @@index([hostUserId])
  @@index([status])
  @@index([startTime])
}

model User {
  id                      String                    @id @default(uuid()) @db.Uuid
  email                   String                    @unique
  name                    String
  role                    UserRole
  parentId                String?                   @db.Uuid
  avatarUrl               String?
  age                     Int?
  gradeLevel              String?                   @map("grade_level")
  mathLevel               Int?                      @map("math_level")
  elaLevel                Int?                      @map("ela_level")
  scienceLevel            Int?                      @map("science_level")
  historyLevel            Int?                      @map("history_level")
  pacingMultiplier        Float                     @default(1.0) @map("pacing_multiplier")
  targetGraduationYear    Int?                      @map("target_graduation_year")
  interests               String[]
  learningStyle           String                    @default("EXPEDITION") // "EXPEDITION" (unified cross-curricular) or "CLASSIC" (siloed subjects with worksheets)
  onboardingComplete      Boolean                   @default(false)
  coppaConsentAt          DateTime?                 @map("coppa_consent_at")
  coppaConsentBy          String?                   @map("coppa_consent_by") @db.Uuid
  dataRetentionDays       Int?                      @default(365) @map("data_retention_days")
  referralCode            String?                   @unique @map("referral_code")
  referredBy              String?                   @map("referred_by") @db.Uuid
  messageCount            Int                       @default(0) @map("message_count")
  messageResetAt          DateTime?                 @map("message_reset_at")
  dataDeletionRequestedAt DateTime?                 @map("data_deletion_requested_at")
  accountLockedAt         DateTime?                 @map("account_locked_at")
  metadata                Json?                     @default("{}")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  joinedGroups            String[]                  @default([]) @map("joined_groups")
  artifacts               Artifact[]
  clubsCreated            Club[]                    @relation("ClubCreator")
  clubs                   ClubMembership[]
  hostedSessions          CollaborativeSession[]    @relation("HostedSessions")
  competitionMatches      CompetitionMatch[]
  conversationMemory      ConversationMemory[]
  groupLogEntries         GroupLogEntry[]
  groupMemberships        GroupMembership[]
  groupMessages           GroupMessage[]
  highlights              Highlight[]
  learningGaps            LearningGap[]
  learningPlans           LearningPlan?
  onboardingProgress      OnboardingProgress?
  opportunities           Opportunity[]             @relation("OpportunityCreator")
  placementAssessments    PlacementAssessment[]
  projects                Project[]                 @relation("ProjectCreator")
  referralsReceived       Referral[]                @relation("Referee")
  referralsMade           Referral[]                @relation("Referrer")
  reflections             ReflectionEntry[]
  reviewSchedules         ReviewSchedule[]
  groupsCreated           ScienceGroup[]            @relation("GroupCreator")
  groupsModerated         ScienceGroup[]            @relation("GroupModerator")
  standardsProgress       StudentStandardProgress[]
  subscription            Subscription?
  approvedEntries         TranscriptEntry[]         @relation("TranscriptApprover")
  transcriptEntries       TranscriptEntry[]
  sourceGapRequests       SourceGapRequest[]
  parent                  User?                     @relation("ParentToChild", fields: [parentId], references: [id])
  children                User[]                    @relation("ParentToChild")
  userActivities          UserActivity[]            @relation("UserActivities")
  conceptMastery          UserConceptMastery[]
  mfaCredential           UserMFACredential?
  investigations          Investigation[]
  createdShareLinks       ShareLink[]               @relation("ShareLinkCreator")
  cachedLessons           CachedLesson[]            @relation("CachedLessons")
  dailyReflections        DailyReflection[]         @relation("StudentReflections")
  bookClubMemberships     BookClubMember[]
  bookClubPosts           BookClubPost[]

  @@index([email])
  @@index([role])
  @@index([parentId])
  @@index([dataDeletionRequestedAt])
}

model Club {
  id          String           @id @default(uuid()) @db.Uuid
  name        String
  description String
  subject     String?
  ageRange    String?          @map("age_range")
  isPublic    Boolean          @default(true) @map("is_public")
  createdById String           @db.Uuid
  isActive    Boolean
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  createdBy   User             @relation("ClubCreator", fields: [createdById], references: [id])
  memberships ClubMembership[]
  projects    Project[]
}

model ClubMembership {
  userId   String   @db.Uuid
  clubId   String   @db.Uuid
  role     ClubRole
  joinedAt DateTime @default(now()) @map("joined_at")
  club     Club     @relation(fields: [clubId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@id([userId, clubId])
  @@index([userId])
  @@index([clubId])
}

model Project {
  id             String        @id @default(uuid()) @db.Uuid
  title          String
  description    String
  clubId         String?       @db.Uuid
  createdById    String        @db.Uuid
  status         ProjectStatus
  serviceGoal    String        @map("service_goal")
  intendedImpact String        @map("intended_impact")
  actualImpact   String?       @map("actual_impact")
  curriculumUnit String?       @map("curriculum_unit")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  artifacts      Artifact[]
  club           Club?         @relation(fields: [clubId], references: [id])
  createdBy      User          @relation("ProjectCreator", fields: [createdById], references: [id])

  @@index([createdById])
}

model Artifact {
  id                String            @id @default(uuid()) @db.Uuid
  projectId         String            @db.Uuid
  createdById       String            @db.Uuid
  title             String
  type              ArtifactType
  fileUrl           String?           @map("file_url")
  description       String
  isShowcase        Boolean           @default(false) @map("is_showcase")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  createdBy         User              @relation(fields: [createdById], references: [id])
  project           Project           @relation(fields: [projectId], references: [id])
  transcriptEntries TranscriptEntry[]

  @@index([createdById])
}

model Opportunity {
  id               String          @id @default(uuid()) @db.Uuid
  title            String
  type             OpportunityType
  description      String
  url              String?
  deadline         DateTime?
  ageRange         String?         @map("age_range")
  matchedInterests String[]        @map("matched_interests")
  isActive         Boolean         @map("is_active")
  createdById      String          @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  createdBy        User            @relation("OpportunityCreator", fields: [createdById], references: [id])

  @@index([createdById])
}

model TranscriptEntry {
  id                 String        @id @default(uuid()) @db.Uuid
  metadata           Json?         @default("{}")
  userId             String?       @db.Uuid
  activityName       String        @map("activity_name")
  mappedSubject      String        @map("mapped_subject")
  creditsEarned      Decimal       @map("credits_earned") @db.Decimal(10, 2)
  gradeLevel         String?       @map("grade_level")
  evidenceArtifactId String?       @db.Uuid
  dateCompleted      DateTime      @map("date_completed")
  approvedById       String?       @db.Uuid
  notes              String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  externalProofUrl   String?       @map("external_proof_url")
  validationType     String        @default("internal") @map("validation_type")
  masteryEvidence    Json?         @map("mastery_evidence")
  planStandardId     String?       @map("plan_standard_id") @db.Uuid
  approvedBy         User?         @relation("TranscriptApprover", fields: [approvedById], references: [id])
  evidenceArtifact   Artifact?     @relation(fields: [evidenceArtifactId], references: [id])
  planStandard       PlanStandard? @relation(fields: [planStandardId], references: [id])
  user               User?         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([mappedSubject])
  @@index([planStandardId])
}

model Concept {
  id              String                 @id @default(uuid()) @db.Uuid
  name            String
  description     String
  subjectArea     String                 @map("subject_area")
  gradeBand       String?                @map("grade_band")
  embedding       Unsupported("vector")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  activities      ConceptActivity[]
  prerequisites   ConceptPrerequisite[]  @relation("ConceptPrereqs")
  dependents      ConceptPrerequisite[]  @relation("ConceptDependents")
  learningGaps    LearningGap[]
  reviewSchedules ReviewSchedule[]
  skillMappings   SkillStandardMapping[]
  userMastery     UserConceptMastery[]
}

model ConceptPrerequisite {
  conceptId      String  @db.Uuid
  prerequisiteId String  @db.Uuid
  concept        Concept @relation("ConceptPrereqs", fields: [conceptId], references: [id])
  prerequisite   Concept @relation("ConceptDependents", fields: [prerequisiteId], references: [id])

  @@id([conceptId, prerequisiteId])
  @@index([conceptId])
}

model ConceptActivity {
  id                  String   @id @default(uuid()) @db.Uuid
  conceptId           String   @db.Uuid
  activityDescription String   @map("activity_description")
  creditMapping       String   @map("credit_mapping")
  suggestedExtension  String   @map("suggested_extension")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  concept             Concept  @relation(fields: [conceptId], references: [id])

  @@index([conceptId])
}

model TimelineEntry {
  id             String     @id @default(uuid()) @db.Uuid
  year           Int
  title          String
  description    String
  worldviewNote  String     @map("worldview_note")
  sourceType     SourceType @map("source_type")
  sourceCitation String?    @map("source_citation")
  curriculumUnit String?    @map("curriculum_unit")
  tags           String[]
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
}

model HippocampusDocument {
  id         String                @id @default(uuid()) @db.Uuid
  title      String
  content    String
  metadata   Json
  sourceType SourceType            @map("source_type")
  embedding  Unsupported("vector")
  chunkIndex Int                   @map("chunk_index")
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  @@index([sourceType])
}

model ConversationMemory {
  id         String                @id @default(uuid()) @db.Uuid
  userId     String                @db.Uuid
  sessionId  String                @map("session_id")
  role       ConversationRole
  content    String
  metadata   Json
  embedding  Unsupported("vector")
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")
  importance Float                 @default(0.5)
  user       User                  @relation(fields: [userId], references: [id])

  @@index([userId, sessionId])
  @@index([createdAt])
  @@index([userId, importance])
}

model LearningGap {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @db.Uuid
  conceptId    String              @db.Uuid
  detectedAt   DateTime            @map("detected_at")
  severity     LearningGapSeverity
  addressed    Boolean             @default(false)
  addressedVia String?             @map("addressed_via")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  concept      Concept             @relation(fields: [conceptId], references: [id])
  user         User                @relation(fields: [userId], references: [id])
}

model ReflectionEntry {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @db.Uuid
  type            ReflectionType
  activitySummary String         @map("activity_summary")
  promptUsed      String         @map("prompt_used")
  studentResponse String?        @map("student_response")
  aiFollowUp      String?        @map("ai_follow_up")
  conceptsTagged  String[]       @map("concepts_tagged")
  insightScore    Float?         @map("insight_score")
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  user            User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
}

model ReviewSchedule {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  conceptId      String    @db.Uuid
  nextReviewAt   DateTime  @map("next_review_at")
  interval       Float     @default(1)
  easeFactor     Float     @default(2.5) @map("ease_factor")
  repetitions    Int       @default(0)
  lastQuality    Int?      @map("last_quality")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  concept        Concept   @relation(fields: [conceptId], references: [id])
  user           User      @relation(fields: [userId], references: [id])

  @@unique([userId, conceptId])
  @@index([userId, nextReviewAt])
}

model UserConceptMastery {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  conceptId     String   @db.Uuid
  masteryLevel  Float    @default(0.0) @map("mastery_level")
  lastPracticed DateTime @default(now()) @map("last_practiced")
  history       Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  concept       Concept  @relation(fields: [conceptId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, conceptId])
  @@index([userId])
}

model UserInteractionStats {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  sessionId      String   @map("session_id")
  messageId      String   @map("message_id")
  responseTimeMs Int      @map("response_time_ms")
  editDistance   Int      @map("edit_distance")
  sentimentScore Float    @map("sentiment_score")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, createdAt])
  @@map("user_interaction_stats")
}

model LLMTrace {
  id            String   @id @default(uuid()) @db.Uuid
  traceId       String   @map("trace_id")
  agentNode     String   @map("agent_node")
  modelId       String   @map("model_id")
  promptTokens  Int      @default(0) @map("prompt_tokens")
  outputTokens  Int      @default(0) @map("output_tokens")
  totalTokens   Int      @default(0) @map("total_tokens")
  latencyMs     Int      @map("latency_ms")
  estimatedCost Float    @default(0) @map("estimated_cost")
  success       Boolean  @default(true)
  errorMessage  String?  @map("error_message")
  userId        String?  @db.Uuid
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([traceId])
  @@index([agentNode])
  @@index([createdAt])
  @@index([userId])
}

model Highlight {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  messageId String?  @db.Uuid
  content   String
  type      String
  source    String
  impact    String?
  userNote  String?  @map("user_note")
  intent    String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model OnboardingProgress {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @unique @db.Uuid
  completedSteps String[]  @map("completed_steps")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @unique @db.Uuid
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  credits              Decimal            @default(0) @db.Decimal(10, 2)
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

model Referral {
  id           String         @id @default(uuid()) @db.Uuid
  referrerId   String         @map("referrer_id") @db.Uuid
  refereeId    String         @map("referee_id") @db.Uuid
  status       ReferralStatus @default(PENDING)
  creditAmount Decimal        @default(10.00) @map("credit_amount") @db.Decimal(10, 2)
  createdAt    DateTime       @default(now()) @map("created_at")
  paidAt       DateTime?      @map("paid_at")
  creditedAt   DateTime?      @map("credited_at")
  referee      User           @relation("Referee", fields: [refereeId], references: [id])
  referrer     User           @relation("Referrer", fields: [referrerId], references: [id])

  @@index([referrerId])
  @@index([refereeId])
}

model AIJob {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String?   @db.Uuid
  sessionId   String    @map("session_id")
  status      JobStatus @default(PENDING)
  intent      String?
  prompt      String
  result      String?
  error       String?
  metadata    Json?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([sessionId])
  @@index([status])
}

model StateStandard {
  id                      String                    @id @default(uuid()) @db.Uuid
  standardCode            String                    @map("standard_code")
  jurisdiction            String
  subject                 String
  gradeLevel              String                    @map("grade_level")
  statementText           String                    @map("statement_text")
  description             String?
  masteryIndicators       Json?                     @map("mastery_indicators")
  typicalMicrocreditValue Decimal?                  @map("typical_microcredit_value") @db.Decimal(10, 4)
  learningComponents      LearningComponent[]
  planStandards           PlanStandard[]
  skillMappings           SkillStandardMapping[]
  studentProgress         StudentStandardProgress[]

  @@unique([standardCode, jurisdiction])
  @@index([jurisdiction, subject])
  @@index([jurisdiction, gradeLevel])
}

model LearningComponent {
  id             String        @id @default(uuid()) @db.Uuid
  standardId     String        @map("standard_id") @db.Uuid
  componentText  String        @map("component_text")
  componentOrder Int?          @map("component_order")
  standard       StateStandard @relation(fields: [standardId], references: [id], onDelete: Cascade)

  @@index([standardId])
}

model SkillStandardMapping {
  id                String            @id @default(uuid()) @db.Uuid
  conceptId         String            @map("concept_id") @db.Uuid
  standardId        String            @map("standard_id") @db.Uuid
  alignmentStrength AlignmentStrength @default(FULL) @map("alignment_strength")
  notes             String?
  concept           Concept           @relation(fields: [conceptId], references: [id])
  standard          StateStandard     @relation(fields: [standardId], references: [id])

  @@unique([conceptId, standardId])
  @@index([conceptId])
  @@index([standardId])
}

model StudentStandardProgress {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  standardId         String        @map("standard_id") @db.Uuid
  mastery            MasteryLevel  @default(INTRODUCED)
  sourceType         String?       @map("source_type")
  sourceId           String?       @map("source_id")
  evidence           Json?
  demonstratedAt     DateTime      @default(now()) @map("demonstrated_at")
  lastActivityAt     DateTime?     @map("last_activity_at")
  microcreditsEarned Decimal       @default(0) @map("microcredits_earned") @db.Decimal(10, 4)
  standard           StateStandard @relation(fields: [standardId], references: [id])
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, standardId])
  @@index([userId])
  @@index([standardId])
  @@index([userId, mastery])
}

model PlacementAssessment {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  status          AssessmentStatus @default(IN_PROGRESS)
  currentSubject  String?          @map("current_subject")
  responses       Json?
  results         Json?
  learningProfile Json?            @map("learning_profile")
  startedAt       DateTime         @default(now()) @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId])
}

model Investigation {
  id         String                @id @default(cuid())
  title      String
  summary    String
  userId     String                @db.Uuid
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  sources    InvestigationSource[]
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareLinks ShareLink[]

  @@map("investigations")
}

model InvestigationSource {
  id              String        @id @default(cuid())
  title           String
  content         String
  sourceType      SourceType
  investigationId String
  createdAt       DateTime      @default(now())
  investigation   Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@map("investigation_sources")
}

model ShareLink {
  id              String        @id @default(cuid())
  investigationId String
  createdBy       String        @db.Uuid
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  creator         User          @relation("ShareLinkCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  investigation   Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@map("share_links")
}

model LearningPlan {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @unique @map("user_id") @db.Uuid
  state          String
  graduationYear Int            @map("graduation_year")
  lastReviewedAt DateTime?      @map("last_reviewed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  planStandards  PlanStandard[]

  @@index([userId])
  @@index([state])
}

model PlanStandard {
  id                String             @id @default(uuid()) @db.Uuid
  planId            String             @map("plan_id") @db.Uuid
  standardId        String             @map("standard_id") @db.Uuid
  microcreditValue  Decimal            @map("microcredit_value") @db.Decimal(10, 4)
  customNotes       String?            @map("custom_notes")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  plan              LearningPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  standard          StateStandard      @relation(fields: [standardId], references: [id])
  activities        StandardActivity[]
  transcriptEntries TranscriptEntry[]

  @@unique([planId, standardId])
  @@index([planId])
  @@index([standardId])
  @@index([isActive])
}

model StandardActivity {
  id               String       @id @default(uuid()) @db.Uuid
  planStandardId   String       @map("plan_standard_id") @db.Uuid
  activityType     String       @map("activity_type")
  activityMetadata Json?        @map("activity_metadata")
  masteryThreshold Json?        @map("mastery_threshold")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  planStandard     PlanStandard @relation(fields: [planStandardId], references: [id], onDelete: Cascade)

  @@index([planStandardId])
  @@index([activityType])
}

model ScienceGroup {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  focus            String
  description      String
  currentChallenge String            @map("current_challenge")
  isPublic         Boolean           @default(true) @map("is_public")
  creatorId        String            @map("creator_id") @db.Uuid
  moderatorId      String?           @map("moderator_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  logEntries       GroupLogEntry[]
  memberships      GroupMembership[]
  messages         GroupMessage[]
  projects         GroupProject[]
  creator          User              @relation("GroupCreator", fields: [creatorId], references: [id])
  moderator        User?             @relation("GroupModerator", fields: [moderatorId], references: [id])

  @@index([creatorId])
  @@index([isPublic])
}

model GroupMembership {
  id       String       @id @default(uuid()) @db.Uuid
  userId   String       @map("user_id") @db.Uuid
  groupId  String       @map("group_id") @db.Uuid
  role     GroupRole    @default(MEMBER)
  joinedAt DateTime     @default(now()) @map("joined_at")
  group    ScienceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model GroupMessage {
  id         String       @id @default(uuid()) @db.Uuid
  groupId    String       @map("group_id") @db.Uuid
  authorId   String       @map("author_id") @db.Uuid
  content    String
  aiMediated Boolean      @default(false) @map("ai_mediated")
  createdAt  DateTime     @default(now()) @map("created_at")
  author     User         @relation(fields: [authorId], references: [id])
  group      ScienceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([authorId])
  @@index([createdAt])
}

model GroupProject {
  id          String          @id @default(uuid()) @db.Uuid
  groupId     String          @map("group_id") @db.Uuid
  title       String
  description String
  status      ProjectStatus   @default(ACTIVE)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  logEntries  GroupLogEntry[]
  group       ScienceGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model GroupLogEntry {
  id        String        @id @default(uuid()) @db.Uuid
  groupId   String        @map("group_id") @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  content   String
  projectId String?       @map("project_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at")
  group     ScienceGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  project   GroupProject? @relation(fields: [projectId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@index([groupId])
  @@index([userId])
}

model Competition {
  id               String             @id @default(uuid()) @db.Uuid
  name             String
  organization     String
  type             CompetitionType
  description      String
  deadline         DateTime?
  eligibilityRules Json               @map("eligibility_rules")
  themes           String[]
  ageRange         String?            @map("age_range")
  gradeRange       String?            @map("grade_range")
  url              String?
  year             Int                @default(2026)
  isActive         Boolean            @default(true) @map("is_active")
  lastScrapedAt    DateTime?          @map("last_scraped_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  matches          CompetitionMatch[]

  @@index([type])
  @@index([deadline])
  @@index([isActive])
  @@index([lastScrapedAt])
}

model CompetitionMatch {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  competitionId  String      @map("competition_id") @db.Uuid
  matchScore     Float       @map("match_score")
  matchReason    String      @map("match_reason")
  projectContext String?     @map("project_context")
  dismissed      Boolean     @default(false)
  createdAt      DateTime    @default(now()) @map("created_at")
  competition    Competition @relation(fields: [competitionId], references: [id])
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([competitionId])
  @@index([dismissed])
}

model GlobalContentCache {
  id         String   @id @default(uuid()) @db.Uuid
  module     String
  topicKey   String   @map("topic_key")
  gradeLevel String   @map("grade_level")
  content    Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([module, topicKey, gradeLevel])
  @@index([module, topicKey, gradeLevel])
  @@map("global_content_cache")
}

model LivingBook {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  title         String
  author        String
  description   String?
  coverUrl      String?  @map("cover_url")
  readingLevel  String?  @map("reading_level")
  genre         String?
  gutenbergId   String?  @map("gutenberg_id")
  isDownloaded  Boolean  @default(false) @map("is_downloaded")
  epubFileUrl   String?  @map("epub_file_url")
  sourceLibrary String?  @map("source_library")
  pdfUrl        String?  @map("pdf_url")
  externalUrl   String?  @map("external_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([gutenbergId])
  @@index([isDownloaded])
  @@map("living_books")
}

